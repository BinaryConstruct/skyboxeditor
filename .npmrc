# Skip Playwright's ~300MB browser download on install. `playwright` is only a
# devDependency for occasional local browser checks; CI/CD (GitHub Actions,
# Cloudflare Pages) never needs the browsers, and downloading them bloats and
# slows every `npm ci`.
#
# npm exposes any .npmrc key `foo=bar` to lifecycle scripts as `npm_config_foo`,
# and Playwright's installer reads `npm_config_playwright_skip_browser_download`
# as a fallback for the PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD env var. This keeps the
# skip repo-side, so no build-platform env var is required.
#
# Note: npm prints a cosmetic "Unknown project config" warning for this custom
# key; it is harmless and does not fail the install.
playwright_skip_browser_download=1
