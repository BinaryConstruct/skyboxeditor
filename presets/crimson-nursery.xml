<?xml version="1.0" encoding="utf-8" ?>
<!-- v2 showcase: H-alpha star-forming region — warped emission clouds,
     dust extinction, catalog stars with Hubble-cross flares -->
<spacescapelayers>
    <layer>
        <name>Ha Emission Clouds</name>
        <type>noise</type>
        <seed>42</seed>
        <noiseType>fbm</noiseType>
        <octaves>8</octaves>
        <gain>0.55</gain>
        <lacunarity>2.15</lacunarity>
        <scale>1.3</scale>
        <powerAmount>1.5</powerAmount>
        <shelfAmount>0.32</shelfAmount>
        <ditherAmount>0.02</ditherAmount>
        <warpStrength>0.9</warpStrength>
        <warpScale>2</warpScale>
        <colorRamp>0 0.01 0 0.01 1; 0.4 0.22 0.02 0.06 1; 0.7 0.6 0.1 0.14 1; 0.9 0.9 0.35 0.3 1; 1 1 0.78 0.7 1</colorRamp>
        <innerColor>1 1 1 1</innerColor>
        <outerColor>0 0 0 1</outerColor>
        <sourceBlendFactor>one</sourceBlendFactor>
        <destBlendFactor>one</destBlendFactor>
        <previewTextureSize>256</previewTextureSize>
    </layer>
    <layer>
        <name>Nursery Core</name>
        <type>volumetric</type>
        <seed>6</seed>
        <noiseType>ridged</noiseType>
        <octaves>7</octaves>
        <gain>0.55</gain>
        <lacunarity>2.3</lacunarity>
        <offset>1</offset>
        <scale>1.6</scale>
        <powerAmount>1.4</powerAmount>
        <shelfAmount>0.3</shelfAmount>
        <warpStrength>0.7</warpStrength>
        <warpScale>1.8</warpScale>
        <steps>60</steps>
        <density>5.5</density>
        <absorption>2.8</absorption>
        <shellInner>0.5</shellInner>
        <shellOuter>1.7</shellOuter>
        <colorRamp>0 0.03 0 0.02 1; 0.5 0.35 0.05 0.08 1; 0.8 0.85 0.3 0.2 1; 1 1 0.85 0.6 1</colorRamp>
        <innerColor>1 0.6 0.4 1</innerColor>
        <outerColor>0.05 0.01 0.02 1</outerColor>
        <sourceBlendFactor>one</sourceBlendFactor>
        <destBlendFactor>one_minus_src_alpha</destBlendFactor>
        <previewTextureSize>256</previewTextureSize>
    </layer>
    <layer>
        <name>Dark Globules</name>
        <type>noise</type>
        <seed>13</seed>
        <noiseType>ridged</noiseType>
        <octaves>7</octaves>
        <gain>0.6</gain>
        <lacunarity>2.5</lacunarity>
        <offset>1</offset>
        <scale>2.4</scale>
        <powerAmount>1.3</powerAmount>
        <shelfAmount>0.6</shelfAmount>
        <ditherAmount>0.01</ditherAmount>
        <warpStrength>1.1</warpStrength>
        <warpScale>2.6</warpScale>
        <innerColor>0.5 0.42 0.36 1</innerColor>
        <outerColor>0 0 0 1</outerColor>
        <sourceBlendFactor>zero</sourceBlendFactor>
        <destBlendFactor>one_minus_src_colour</destBlendFactor>
        <previewTextureSize>256</previewTextureSize>
    </layer>
    <layer>
        <name>Embedded Stars</name>
        <type>points</type>
        <seed>77</seed>
        <numPoints>24000</numPoints>
        <pointSize>1</pointSize>
        <pointSizeMax>3</pointSizeMax>
        <colorMode>blackbody</colorMode>
        <tempMin>2600</tempMin>
        <tempMax>9000</tempMax>
        <magnitudePower>3</magnitudePower>
        <sourceBlendFactor>one</sourceBlendFactor>
        <destBlendFactor>one</destBlendFactor>
    </layer>
    <layer>
        <name>Catalog Stars</name>
        <type>billboards</type>
        <seed>1</seed>
        <numBillboards>200</numBillboards>
        <minSize>0.015</minSize>
        <maxSize>0.045</maxSize>
        <texture>proc:hubble</texture>
        <dataFile>stars.csv</dataFile>
        <nearColor>1 1 1 1</nearColor>
        <farColor>1 1 1 1</farColor>
        <sourceBlendFactor>one</sourceBlendFactor>
        <destBlendFactor>one</destBlendFactor>
    </layer>
</spacescapelayers>
